# CoNLL-2003 label map (index → IOB2/BIO tag)
CONLL_LABEL_NAMES = [
    "O",        # 0 – Outside
    "B-PER",    # 1 – Beginning of Person
    "I-PER",    # 2 – Inside of Person
    "B-ORG",    # 3 – Beginning of Organisation
    "I-ORG",    # 4 – Inside of Organisation
    "B-LOC",    # 5 – Beginning of Location
    "I-LOC",    # 6 – Inside of Location
    "B-MISC",   # 7 – Beginning of Miscellaneous
    "I-MISC",   # 8 – Inside of Miscellaneous
]
LABEL2ID = {l: i for i, l in enumerate(CONLL_LABEL_NAMES)}
ID2LABEL = {i: l for l, i in LABEL2ID.items()}
NUM_LABELS = len(CONLL_LABEL_NAMES)


def load_conll2003(max_samples: int = None):
    """
    Load CoNLL-2003 via HuggingFace datasets.
    Returns train / validation / test splits as lists of
    {"tokens": [...], "tags": [...]}  where tags are BIO strings.
    """
    print("[DATA] Loading CoNLL-2003 …")
    raw = load_dataset("conll2003", trust_remote_code=True)

    def convert_split(split_data):
        records = []
        for row in split_data:
            tokens = row["tokens"]
            tags   = [CONLL_LABEL_NAMES[t] for t in row["ner_tags"]]
            records.append({"tokens": tokens, "tags": tags})
        return records

    train = convert_split(raw["train"])
    val   = convert_split(raw["validation"])
    test  = convert_split(raw["test"])

    if max_samples:
        train = train[:max_samples]
        val   = val[:max_samples // 5]
        test  = test[:max_samples // 5]

    print(f"  Train : {len(train):,} sentences")
    print(f"  Val   : {len(val):,} sentences")
    print(f"  Test  : {len(test):,} sentences")
    return train, val, test


