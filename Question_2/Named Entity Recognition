def validate_bio(records):
    """Check BIO alignment: every I-X must be preceded by B-X or I-X."""
    errors = 0
    for r in records:
        prev = "O"
        for tag in r["tags"]:
            if tag.startswith("I-"):
                etype = tag[2:]
                if not (prev == f"B-{etype}" or prev == f"I-{etype}"):
                    errors += 1
            prev = tag
    print(f"\n[BIO] Alignment validation: {errors} violations found "
          f"({'CLEAN' if errors == 0 else 'WARNING'})")
    return errors == 0


