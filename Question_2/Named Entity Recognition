#  SECTION 4 – BERT fine-tuning (transformer-based model)
# ════════════════════════════════════════════════════════════════════════════

MODEL_CHECKPOINT = "bert-base-cased"   # cased is preferred for NER


def tokenize_and_align(examples, tokenizer, label_all_tokens=False):
    """
    Tokenize words and align NER labels to sub-word tokens.
    Words split into multiple sub-tokens get the label on the first sub-token;
    subsequent sub-tokens get -100 (ignored by loss).
    """
    tokenized = tokenizer(
        examples["tokens"],
        truncation=True,
        is_split_into_words=True,
        max_length=128,
        padding="max_length",
    )
    labels = []
    for i, tag_ids in enumerate(examples["ner_tags"]):
        word_ids = tokenized.word_ids(batch_index=i)
        prev_word_id = None
        label_ids = []
        for word_id in word_ids:
            if word_id is None:
                label_ids.append(-100)
            elif word_id != prev_word_id:
                label_ids.append(tag_ids[word_id])
            else:
                label_ids.append(tag_ids[word_id] if label_all_tokens else -100)
            prev_word_id = word_id
        labels.append(label_ids)
    tokenized["labels"] = labels
    return tokenized


def compute_metrics_for_trainer(p):
    """Callback for HuggingFace Trainer."""
    predictions, labels = p
    predictions = np.argmax(predictions, axis=2)
    true_preds = [
        [CONLL_LABEL_NAMES[pred] for pred, label in zip(prediction, label) if label != -100]
        for prediction, label in zip(predictions, labels)
    ]
    true_labels = [
        [CONLL_LABEL_NAMES[label] for label in label_seq if label != -100]
        for label_seq in labels
    ]
    return {
        "precision": precision_score(true_labels, true_preds),
        "recall"   : recall_score(true_labels, true_preds),
        "f1"       : f1_score(true_labels, true_preds),
    }


def train_bert(train_raw, val_raw, test_raw, epochs=3):
    print("\n" + "="*65)
    print(f"  MODEL 3 : BERT fine-tuned ({MODEL_CHECKPOINT})")
    print("="*65)

    # reload from HuggingFace in its native format for the Trainer API
    raw = load_dataset("conll2003", trust_remote_code=True)

    tokenizer = AutoTokenizer.from_pretrained(MODEL_CHECKPOINT)

    def preprocess(batch):
        return tokenize_and_align(batch, tokenizer)

    tokenized = raw.map(preprocess, batched=True)

    model = AutoModelForTokenClassification.from_pretrained(
        MODEL_CHECKPOINT,
        num_labels=NUM_LABELS,
        id2label=ID2LABEL,
        label2id=LABEL2ID,
        ignore_mismatched_sizes=True,
    )

    # limit train size if requested (already sliced in raw_train_raw)
    max_train = len(train_raw)
    max_val   = len(val_raw)
    max_test  = len(test_raw)
    tokenized["train"]      = tokenized["train"].select(range(min(max_train, len(tokenized["train"]))))
    tokenized["validation"] = tokenized["validation"].select(range(min(max_val, len(tokenized["validation"]))))
    tokenized["test"]       = tokenized["test"].select(range(min(max_test, len(tokenized["test"]))))

    args = TrainingArguments(
        output_dir="./bert_ner_ckpt",
        num_train_epochs=epochs,
        per_device_train_batch_size=16,
        per_device_eval_batch_size=32,
        warmup_ratio=0.1,
        weight_decay=0.01,
        learning_rate=2e-5,
        eval_strategy="epoch",
        save_strategy="epoch",
        load_best_model_at_end=True,
        metric_for_best_model="f1",
        logging_steps=50,
        seed=SEED,
        report_to="none",
    )

    data_collator = DataCollatorForTokenClassification(tokenizer)

    trainer = Trainer(
        model=model,
        args=args,
        train_dataset=tokenized["train"],
        eval_dataset=tokenized["validation"],
        tokenizer=tokenizer,
        data_collator=data_collator,
        compute_metrics=compute_metrics_for_trainer,
    )

    print("[BERT] Training …")
    trainer.train()

    # ── final evaluation on validation ──
    print("[BERT] Evaluating on validation set …")
    preds_output = trainer.predict(tokenized["validation"])
    raw_preds    = np.argmax(preds_output.predictions, axis=2)
    raw_labels   = preds_output.label_ids

    y_true, y_pred = [], []
    for pred_seq, label_seq in zip(raw_preds, raw_labels):
        y_true.append([CONLL_LABEL_NAMES[l] for l in label_seq if l != -100])
        y_pred.append([CONLL_LABEL_NAMES[p]
                       for p, l in zip(pred_seq, label_seq) if l != -100])

    _, metrics = evaluate(y_true, y_pred, model_name="BERT")
    return trainer, tokenizer, metrics


