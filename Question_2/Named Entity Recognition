def word_features(sentence: List[str], i: int) -> Dict:
    """
    Hand-crafted feature function for CRF.
    Captures orthographic, positional, and contextual signals.
    """
    word = sentence[i]

    feats = {
        "bias"            : 1.0,
        "word.lower()"    : word.lower(),
        "word[-3:]"       : word[-3:],
        "word[-2:]"       : word[-2:],
        "word[:3]"        : word[:3],
        "word.isupper()"  : word.isupper(),
        "word.istitle()"  : word.istitle(),
        "word.isdigit()"  : word.isdigit(),
        "word.has_hyphen" : "-" in word,
        "word.len"        : len(word),
        "BOS"             : i == 0,
        "EOS"             : i == len(sentence) - 1,
    }

    # previous token
    if i > 0:
        prev = sentence[i - 1]
        feats.update({
            "-1:word.lower()": prev.lower(),
            "-1:istitle"     : prev.istitle(),
            "-1:isupper"     : prev.isupper(),
        })
    else:
        feats["BOS"] = True

    # next token
    if i < len(sentence) - 1:
        nxt = sentence[i + 1]
        feats.update({
            "+1:word.lower()": nxt.lower(),
            "+1:istitle"     : nxt.istitle(),
            "+1:isupper"     : nxt.isupper(),
        })
    else:
        feats["EOS"] = True

    # bigram window
    if i > 1:
        feats["-2:word.lower()"] = sentence[i - 2].lower()
    if i < len(sentence) - 2:
        feats["+2:word.lower()"] = sentence[i + 2].lower()

    return feats


def sentences_to_features(records):
    return [[word_features(r["tokens"], i)
             for i in range(len(r["tokens"]))]
            for r in records]


def sentences_to_labels(records):
    return [r["tags"] for r in records]


def train_crf(train, val):
    print("\n" + "="*65)
    print("  MODEL 1 : CRF (Conditional Random Field)")
    print("="*65)

    X_train = sentences_to_features(train)
    y_train = sentences_to_labels(train)
    X_val   = sentences_to_features(val)
    y_val   = sentences_to_labels(val)

    print("[CRF] Extracting features …")
    crf = sklearn_crfsuite.CRF(
        algorithm="lbfgs",
        c1=0.1,
        c2=0.1,
        max_iterations=100,
        all_possible_transitions=True,
    )
    t0 = time.time()
    crf.fit(X_train, y_train)
    print(f"[CRF] Training done in {time.time()-t0:.1f}s")

    y_pred = crf.predict(X_val)
    report, metrics = evaluate(y_val, y_pred, model_name="CRF")
    return crf, metrics


