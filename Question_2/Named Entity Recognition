def main():
    parser = argparse.ArgumentParser(description="NER Pipeline")
    parser.add_argument("--model", default="all",
                        choices=["crf", "bilstm", "bert", "all"])
    parser.add_argument("--max_samples", type=int, default=None,
                        help="Limit training sentences (None = full dataset)")
    parser.add_argument("--epochs_bilstm", type=int, default=5)
    parser.add_argument("--epochs_bert",   type=int, default=3)
    args = parser.parse_args()

    # ── 1. Load data ────────────────────────────────────────────────────────
    train, val, test = load_conll2003(max_samples=args.max_samples)
    describe_dataset(train)
    validate_bio(train)

    all_metrics   = []
    all_errors    = {}

    # ── 2. CRF ──────────────────────────────────────────────────────────────
    if args.model in ("crf", "all"):
        crf_model, crf_metrics_dict = train_crf(train, val)
        all_metrics.append(crf_metrics_dict)

        # error analysis needs predictions → regenerate
        X_val = sentences_to_features(val)
        y_val = sentences_to_labels(val)
        y_pred_crf = crf_model.predict(X_val)
        errs = error_analysis(y_val, y_pred_crf, model_name="CRF")
        all_errors["CRF"] = errs

    # ── 3. BiLSTM-CRF ───────────────────────────────────────────────────────
    if args.model in ("bilstm", "all"):
        bilstm_model, vocab, bilstm_metrics_dict = train_bilstm_crf(
            train, val, epochs=args.epochs_bilstm)
        all_metrics.append(bilstm_metrics_dict)

        # regenerate preds for error analysis
        ds_val = NERDataset(val, vocab, LABEL2ID)
        dl_val = DataLoader(ds_val, batch_size=64)
        bilstm_model.eval()
        y_true_bl, y_pred_bl = [], []
        with torch.no_grad():
            for x, y, mask in dl_val:
                x, mask = x.to(DEVICE), mask.to(DEVICE)
                preds = bilstm_model(x, mask=mask.bool())
                for pred_seq, true_seq, m in zip(preds, y.tolist(), mask.tolist()):
                    length = sum(m.tolist())
                    y_true_bl.append([ID2LABEL[t] for t in true_seq[:length]])
                    y_pred_bl.append([ID2LABEL[p] for p in pred_seq[:length]])
        errs = error_analysis(y_true_bl, y_pred_bl, model_name="BiLSTM-CRF")
        all_errors["BiLSTM-CRF"] = errs

    # ── 4. BERT ─────────────────────────────────────────────────────────────
    if args.model in ("bert", "all"):
        bert_trainer, bert_tok, bert_metrics_dict = train_bert(
            train, val, test, epochs=args.epochs_bert)
        all_metrics.append(bert_metrics_dict)

    # ── 5. Discussion ────────────────────────────────────────────────────────
    contextual_embeddings_discussion()

    # ── 6. Comparison ────────────────────────────────────────────────────────
    if all_metrics:
        print_comparison(all_metrics)

    # ── 7. Save results ──────────────────────────────────────────────────────
    results = {
        "metrics"     : all_metrics,
        "error_analysis": all_errors,
    }
    with open("ner_results.json", "w") as f:
        json.dump(results, f, indent=2)
    print("  Results saved to  ner_results.json\n")


if __name__ == "__main__":
    main()
