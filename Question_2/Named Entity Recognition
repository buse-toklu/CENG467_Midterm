#  SECTION 3 – BiLSTM-CRF (hybrid model)
# ════════════════════════════════════════════════════════════════════════════

def build_vocab(records, min_freq=1):
    counter = Counter()
    for r in records:
        counter.update(r["tokens"])
    vocab = {"<PAD>": 0, "<UNK>": 1}
    for word, freq in counter.items():
        if freq >= min_freq:
            vocab[word] = len(vocab)
    return vocab


class NERDataset(Dataset):
    def __init__(self, records, vocab, label2id, max_len=128):
        self.samples   = []
        self.max_len   = max_len
        self.pad_label = label2id["O"]

        for r in records:
            ids   = [vocab.get(t, vocab["<UNK>"]) for t in r["tokens"]]
            lids  = [label2id[t] for t in r["tags"]]
            mask  = [1] * len(ids)

            # truncate
            ids  = ids[:max_len]
            lids = lids[:max_len]
            mask = mask[:max_len]

            # pad
            pad_len = max_len - len(ids)
            ids  += [0] * pad_len
            lids += [self.pad_label] * pad_len
            mask += [0] * pad_len

            self.samples.append((
                torch.tensor(ids,  dtype=torch.long),
                torch.tensor(lids, dtype=torch.long),
                torch.tensor(mask, dtype=torch.uint8),
            ))

    def __len__(self):  return len(self.samples)
    def __getitem__(self, i): return self.samples[i]


class BiLSTM_CRF(nn.Module):
    def __init__(self, vocab_size, num_labels, embed_dim=100,
                 hidden_dim=256, num_layers=2, dropout=0.3):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=0)
        self.lstm      = nn.LSTM(embed_dim, hidden_dim // 2,
                                 num_layers=num_layers,
                                 batch_first=True,
                                 bidirectional=True,
                                 dropout=dropout if num_layers > 1 else 0)
        self.dropout   = nn.Dropout(dropout)
        self.fc        = nn.Linear(hidden_dim, num_labels)
        self.crf       = CRF(num_labels, batch_first=True)

    def forward(self, x, tags=None, mask=None):
        emb  = self.dropout(self.embedding(x))
        out, _ = self.lstm(emb)
        out  = self.dropout(out)
        emissions = self.fc(out)

        if tags is not None:
            loss = -self.crf(emissions, tags, mask=mask, reduction="mean")
            return loss
        return self.crf.decode(emissions, mask=mask)


def train_bilstm_crf(train, val, epochs=5, batch_size=32, lr=1e-3):
    print("\n" + "="*65)
    print("  MODEL 2 : BiLSTM-CRF (Hybrid)")
    print("="*65)

    vocab    = build_vocab(train)
    ds_train = NERDataset(train, vocab, LABEL2ID)
    ds_val   = NERDataset(val,   vocab, LABEL2ID)

    dl_train = DataLoader(ds_train, batch_size=batch_size, shuffle=True)
    dl_val   = DataLoader(ds_val,   batch_size=batch_size)

    model = BiLSTM_CRF(len(vocab), NUM_LABELS).to(DEVICE)
    opt   = Adam(model.parameters(), lr=lr)
    sched = get_linear_schedule_with_warmup(
        opt,
        num_warmup_steps=len(dl_train),
        num_training_steps=len(dl_train) * epochs,
    )

    best_f1, best_state = 0.0, None

    for epoch in range(1, epochs + 1):
        # ── train ──
        model.train()
        total_loss = 0.0
        for x, y, mask in dl_train:
            x, y, mask = x.to(DEVICE), y.to(DEVICE), mask.to(DEVICE)
            loss = model(x, tags=y, mask=mask.bool())
            opt.zero_grad()
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()
            sched.step()
            total_loss += loss.item()

        avg_loss = total_loss / len(dl_train)

        # ── validate ──
        model.eval()
        y_true_all, y_pred_all = [], []
        with torch.no_grad():
            for x, y, mask in dl_val:
                x, mask = x.to(DEVICE), mask.to(DEVICE)
                preds = model(x, mask=mask.bool())
                for pred_seq, true_seq, m in zip(preds, y.tolist(), mask.tolist()):
                    length = sum(m)
                    y_true_all.append([ID2LABEL[t] for t in true_seq[:length]])
                    y_pred_all.append([ID2LABEL[p] for p in pred_seq[:length]])

        f1 = f1_score(y_true_all, y_pred_all)
        print(f"  Epoch {epoch}/{epochs}  loss={avg_loss:.4f}  val_f1={f1:.4f}")

        if f1 > best_f1:
            best_f1   = f1
            best_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}

    # reload best
    model.load_state_dict({k: v.to(DEVICE) for k, v in best_state.items()})

    # final eval on val
    model.eval()
    y_true_all, y_pred_all = [], []
    with torch.no_grad():
        for x, y, mask in dl_val:
            x, mask = x.to(DEVICE), mask.to(DEVICE)
            preds = model(x, mask=mask.bool())
            for pred_seq, true_seq, m in zip(preds, y.tolist(), mask.tolist()):
                length = sum(m)
                y_true_all.append([ID2LABEL[t] for t in true_seq[:length]])
                y_pred_all.append([ID2LABEL[p] for p in pred_seq[:length]])

    _, metrics = evaluate(y_true_all, y_pred_all, model_name="BiLSTM-CRF")
    return model, vocab, metrics


