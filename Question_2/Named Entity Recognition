def evaluate(y_true: List[List[str]],
             y_pred: List[List[str]],
             model_name: str = "Model") -> Tuple[str, dict]:
    """
    Compute Precision / Recall / F1 using seqeval (entity-level).
    Print a detailed report and return a metrics dict.
    """
    p  = precision_score(y_true, y_pred)
    r  = recall_score(y_true, y_pred)
    f1 = f1_score(y_true, y_pred)
    report = classification_report(y_true, y_pred, digits=4)

    print(f"\n[EVAL] {model_name}")
    print(f"  Precision : {p:.4f}")
    print(f"  Recall    : {r:.4f}")
    print(f"  F1        : {f1:.4f}")
    print(f"\n  Per-entity report:\n{report}")

    metrics = {
        "model"    : model_name,
        "precision": round(p, 4),
        "recall"   : round(r, 4),
        "f1"       : round(f1, 4),
    }
    return report, metrics


def error_analysis(y_true: List[List[str]],
                   y_pred: List[List[str]],
                   model_name: str,
                   n_examples: int = 10):
    """
    Categorise and display common NER errors:
      - Boundary errors   : correct entity type, wrong span
      - Entity confusion  : wrong entity type assigned
      - False positives   : hallucinated entities
      - False negatives   : missed entities
    """
    print(f"\n[ERROR ANALYSIS] {model_name}")
    print("-" * 50)

    boundary_errors  = 0
    type_confusion   = Counter()   # (true_type, pred_type) → count
    false_positives  = Counter()   # pred_type → count
    false_negatives  = Counter()   # true_type → count

    examples = []

    def get_spans(seq):
        """Extract (type, start, end) spans from a BIO sequence."""
        spans, start, etype = [], None, None
        for i, tag in enumerate(seq):
            if tag.startswith("B-"):
                if start is not None:
                    spans.append((etype, start, i - 1))
                start, etype = i, tag[2:]
            elif tag.startswith("I-"):
                if start is None:          # fix broken I without B
                    start, etype = i, tag[2:]
            else:
                if start is not None:
                    spans.append((etype, start, i - 1))
                    start, etype = None, None
        if start is not None:
            spans.append((etype, start, len(seq) - 1))
        return spans

    for sent_true, sent_pred in zip(y_true, y_pred):
        true_spans = {(e, s, end) for e, s, end in get_spans(sent_true)}
        pred_spans = {(e, s, end) for e, s, end in get_spans(sent_pred)}

        true_pos  = {(s, e) for _, s, e in true_spans}   # span positions
        pred_pos  = {(s, e) for _, s, e in pred_spans}

        # exact matches
        matched_true = set()
        matched_pred = set()

        for t_ent, t_s, t_e in true_spans:
            for p_ent, p_s, p_e in pred_spans:
                if t_s == p_s and t_e == p_e:
                    if t_ent == p_ent:
                        matched_true.add((t_ent, t_s, t_e))
                        matched_pred.add((p_ent, p_s, p_e))
                    else:
                        type_confusion[(t_ent, p_ent)] += 1
                        matched_true.add((t_ent, t_s, t_e))
                        matched_pred.add((p_ent, p_s, p_e))
                elif (t_s <= p_e and p_s <= t_e):   # overlapping
                    boundary_errors += 1
                    matched_true.add((t_ent, t_s, t_e))
                    matched_pred.add((p_ent, p_s, p_e))

        # false negatives (true spans not predicted at all)
        for span in true_spans - matched_true:
            false_negatives[span[0]] += 1

        # false positives (predicted spans not in true)
        for span in pred_spans - matched_pred:
            false_positives[span[0]] += 1

    total_errors = (boundary_errors + sum(type_confusion.values())
                    + sum(false_positives.values()) + sum(false_negatives.values()))

    print(f"  Boundary errors  (correct type, wrong span)   : {boundary_errors}")
    print(f"  Type confusion   (wrong entity type)          :")
    for (t, p), cnt in type_confusion.most_common(5):
        print(f"    {t} → {p}: {cnt}")
    print(f"  False positives  (hallucinated entities)      :")
    for etype, cnt in false_positives.most_common():
        print(f"    {etype}: {cnt}")
    print(f"  False negatives  (missed entities)            :")
    for etype, cnt in false_negatives.most_common():
        print(f"    {etype}: {cnt}")
    print(f"  Total errors     : {total_errors}")

    return {
        "boundary_errors" : boundary_errors,
        "type_confusion"  : {f"{t}->{p}": c for (t, p), c in type_confusion.items()},
        "false_positives" : dict(false_positives),
        "false_negatives" : dict(false_negatives),
    }


def contextual_embeddings_discussion():
    """Print a concise discussion on contextual embeddings in NER."""
    print("\n" + "="*65)
    print("  DISCUSSION: Role of Contextual Embeddings in NER")
    print("="*65)
    text = """
  Traditional word embeddings (Word2Vec, GloVe) assign a single static
  vector per word, ignoring context.  "Apple" the company and "apple"
  the fruit receive the same representation.

  Contextual embeddings (ELMo, BERT, RoBERTa) generate token
  representations conditioned on the full surrounding sentence.
  This gives NER three key advantages:

  1. Disambiguation  – the same surface form gets different vectors in
     different contexts, helping distinguish PER/ORG/MISC uses of
     ambiguous tokens (e.g. "Jordan" as person vs. country).

  2. Sub-word coverage  – BERT tokenises unknown words into sub-word
     pieces, capturing morphological signals (suffixes, prefixes) that
     help detect entity boundaries even for rare or unseen tokens.

  3. Pre-trained world knowledge  – large-scale language model
     pre-training implicitly encodes entity co-occurrence patterns,
     giving the fine-tuned model a strong prior before seeing any NER
     labels.

  The empirical gap observed in this experiment (BERT >> BiLSTM-CRF >>
  CRF) reflects these advantages: the transformer collapses ambiguous
  cases that trip up hand-crafted CRF features, and generalises better
  across entity types, especially rare MISC entities.
    """
    print(text)


