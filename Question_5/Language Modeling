from datasets import load_dataset

# Load WikiText-2
dataset = load_dataset("wikitext", "wikitext-2-raw-v1")
train_text = dataset['train']['text']
valid_text = dataset['validation']['text']


import torch
import torch.nn as nn

class LSTMLanguageModel(nn.Module):
    def __init__(self, vocab_size, embed_size, hidden_size, num_layers):
        super(LSTMLanguageModel, self).__init__()
        self.embedding = nn.Embedding(vocab_size, embed_size)

        # batch_first=True makes input shape (batch, seq, feature)
        self.lstm = nn.LSTM(embed_size, hidden_size, num_layers, batch_first=True)

        # Maps hidden state back to vocabulary size for prediction
        self.linear = nn.Linear(hidden_size, vocab_size)

    def forward(self, x, hidden):
        # x shape: (batch_size, sequence_length)
        embeds = self.embedding(x)
        lstm_out, hidden = self.lstm(embeds, hidden)

        # Flatten output to pass through linear layer
        output = self.linear(lstm_out.reshape(-1, lstm_out.size(2)))
        return output, hidden
